import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv('data/housing.csv')

# Area vs Price
plt.scatter(df['area'], df['price'])
plt.xlabel("Area (sq ft)")
plt.ylabel("Price")
plt.title("Area vs Price")
plt.show()

# Bedrooms vs Price
plt.bar(df['bedrooms'], df['price'])
plt.xlabel("Bedrooms")
plt.ylabel("Price")
plt.title("Bedrooms vs Price")
plt.show()
